---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Contact from '../../components/Contact.astro';

const areas = [
  {
    title: "Full Stack Leader",
    description: "Technical depth, strategic thinking, and strong people leadership across four levels: Strategic, Tactical, Operational, and People.",
    href: "/leadership/full-stack-leader",
    icon: "layers",
    color: "emerald",
  },
  {
    title: "Transformation Leader",
    description: "Driving large-scale technical transformations as a Visionary Pragmatist, Empathy-First leader, and Political Navigator.",
    href: "/leadership/transformation-leader",
    icon: "refresh",
    color: "indigo",
  },
  {
    title: "DevEx & QE Leadership",
    description: "Developer Experience and Quality Engineering leadership across six pillars, from mastery of fundamentals to strategic transformation.",
    href: "/leadership/devex-qe-leader",
    icon: "code",
    color: "amber",
  },
  {
    title: "Leadership Breadth",
    description: "Adaptability and demonstrated success in driving technical change across diverse industry and company landscapes.",
    href: "/leadership/leadership-breadth",
    icon: "globe",
    color: "cyan",
  },
];
---

<Layout title="My Leadership Experience | Greg Sypolt">
  <Navigation />
  <div class="pt-16">
    <section class="py-20 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h1 class="text-4xl md:text-5xl font-bold mb-4">
            My <span class="text-emerald-500">Leadership</span> Experience
          </h1>
          <p class="text-lg text-slate-400 max-w-3xl mx-auto leading-relaxed">
            A strategic approach to leadership and transformation as a Developer Experience and Quality Engineering leader, built on technical depth, organizational change, and people-first principles.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          {areas.map((area) => (
            <a href={area.href} class={`group block bg-slate-800/50 p-8 rounded-lg border border-slate-700 hover:border-${area.color}-500 transition-all duration-300 hover:scale-105`}>
              <div class={`w-12 h-12 rounded-lg bg-${area.color}-500/10 flex items-center justify-center mb-6`}>
                {area.icon === "layers" && (
                  <svg class={`w-6 h-6 text-${area.color}-500`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                  </svg>
                )}
                {area.icon === "refresh" && (
                  <svg class={`w-6 h-6 text-${area.color}-500`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                  </svg>
                )}
                {area.icon === "code" && (
                  <svg class={`w-6 h-6 text-${area.color}-500`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                  </svg>
                )}
                {area.icon === "globe" && (
                  <svg class={`w-6 h-6 text-${area.color}-500`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                )}
              </div>
              <h2 class="text-2xl font-bold mb-3 group-hover:text-emerald-500 transition-colors">{area.title}</h2>
              <p class="text-slate-400 leading-relaxed mb-4">{area.description}</p>
              <span class={`text-${area.color}-500 font-medium inline-flex items-center gap-2`}>
                Explore
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
    <Contact />
  </div>
</Layout>
