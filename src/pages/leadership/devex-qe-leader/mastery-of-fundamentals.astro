---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import Contact from '../../../components/Contact.astro';

const capabilities = [
  {
    title: "RAG Migration Assistant",
    description: "Architected and directed development of a RAG-based GenAI migration assistant at FINRA — designed the retrieval indexing strategy, prompt engineering layer, compliance validation, and human-in-the-loop approval workflow. Accelerated Jenkins-to-GitLab pipeline migration from days to hours per pipeline across 700 developers.",
  },
  {
    title: "Front-End Learning Breadth",
    description: "Deliberately learning across frontend ecosystems — Astro for static site generation, React for component architecture, SolidJS for fine-grained reactivity, Vite for modern build tooling. Builds real projects to learn, not just tutorials."
  },
  {
    title: "CI/CD Tooling",
    description: "Led three major CI/CD platform migrations across three organizations — CircleCI to GitHub Actions at EVERFI, Jenkins infrastructure scaling across 100+ applications (web and mobile) at Gannett, and Jenkins to GitLab for 700 developers at FINRA. At FINRA, architected pipeline-as-code standards and a RAG-based GenAI assistant that auto-generates 80% of declarative pipeline syntax, reducing migration time from days to hours. Hands-on with GitHub Actions in personal projects including portfolio and full-stack application deployments.",
  },
  {
    title: "Testing Infrastructure",
    description: "Built testing infrastructure and delivery models from the ground zero across organizations at increasing scale — at Gannett, created a Quality as a Service model across 100+ properties serving three engagement tiers: 30% self-service enablement teaching developers to own their own testing, 60% white glove partnership with planned roll-off once quality goals were met, and 10% embedded dedicated SDETs — scaling from a manual baseline to 14M+ monthly executions across web, mobile, and API layers; at EVERFI, architected a JSON schema-to-UI component mapping system that eliminated 100% of manual testing across 150+ unique courses, regenerating automated test scripts on demand in under 90 seconds.",
  },
  {
    title: "Full-Stack Personal Project",
    description: "Actively building a full-stack fantasy football platform in personal time — SolidJS, Node.js, PostgreSQL, Redis, Docker, and AWS infrastructure. Cloud deployment targeting mid-2026. Deliberately chose SolidJS to learn outside comfort zone. Full testing pyramid applied: Vitest, MSW, fast-check, and Playwright.",
  },
  {
    title: "Platform Migrations",
    description: "COMING SOON",
    // description: "Successful execution of complex infrastructural transitions, such as self-managed Jenkins to GitLab SaaS and on-prem Atlassian to Cloud.",
  },
  {
    title: "Security Integration",
    description: "COMING SOON",
    // description: "Expertise in embedding critical security tooling (SonarQube, BlackDuck, Checkmarx) directly into the CI/CD pipeline (Shift-Left Security).",
  },
  {
    title: "Artifact Management",
    description: "COMING SOON",
    // description: "Proficiency in enterprise-level artifact storage and management systems (JFrog Artifactory).",
  },
  {
    title: "Container Orchestration",
    description: "COMING SOON",
    // description: "Expertise in containerization (Docker) and orchestration (Kubernetes, Terraform) to ensure scalable, reproducible environments.",
  },
];
---

<Layout title="Mastery of the Fundamentals | Greg Sypolt">
  <Navigation />
  <div class="pt-16">
    <section class="py-20 px-4">
      <div class="max-w-6xl mx-auto">
        <!-- Breadcrumb -->
        <nav class="mb-8 text-sm text-slate-400">
          <a href="/leadership" class="hover:text-emerald-500 transition-colors">Leadership</a>
          <span class="mx-2">/</span>
          <a href="/leadership/devex-qe-leader" class="hover:text-emerald-500 transition-colors">DevEx & QE</a>
          <span class="mx-2">/</span>
          <span class="text-slate-200">Mastery of the Fundamentals</span>
        </nav>

        <div class="mb-12">
          <h1 class="text-4xl md:text-5xl font-bold mb-6">
            Mastery of the <span class="text-emerald-500">Fundamentals</span>
          </h1>
          <div class="bg-slate-800/50 p-6 rounded-lg border border-emerald-500/30 mb-8">
            <p class="text-sm text-emerald-500 uppercase tracking-wider mb-2 font-medium">Core Principle</p>
            <p class="text-slate-300 leading-relaxed text-lg">A leader must understand the technical ground truth to effectively set strategy and coach teams.</p>
          </div>
        </div>

        <h2 class="text-2xl md:text-3xl font-bold mb-8">Deep Technical Experience</h2>

        <div class="grid md:grid-cols-2 gap-6">
          {capabilities.map((cap) => (
            <div class="bg-slate-800/50 p-6 rounded-lg border border-slate-700 hover:border-emerald-500 transition-all duration-300">
              <h3 class="text-lg font-bold mb-3 text-emerald-400">{cap.title}</h3>
              <p class="text-slate-400 leading-relaxed">{cap.description}</p>
            </div>
          ))}
        </div>

        <!-- Back link -->
        <div class="mt-16 text-center">
          <a href="/leadership/devex-qe-leader" class="inline-flex items-center gap-2 text-emerald-500 hover:text-emerald-400 transition-colors font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to DevEx & QE Leadership
          </a>
        </div>
      </div>
    </section>
    <Contact />
  </div>
</Layout>
