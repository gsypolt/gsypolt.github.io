---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import Contact from '../../../components/Contact.astro';

---

<Layout title="Strategic Leadership | Greg Sypolt">
  <Navigation />
  <div class="pt-16">
    <section class="py-20 px-4">
      <div class="max-w-6xl mx-auto">
        <!-- Breadcrumb -->
        <nav class="mb-8 text-sm text-slate-400">
          <a href="/leadership" class="hover:text-emerald-500 transition-colors">Leadership</a>
          <span class="mx-2">/</span>
          <a href="/leadership/devex-qe-leader" class="hover:text-emerald-500 transition-colors">DevEx & QE</a>
          <span class="mx-2">/</span>
          <span class="text-slate-200">Strategic Leadership</span>
        </nav>

        <div class="mb-12">
          <h1 class="text-4xl md:text-5xl font-bold mb-6">
            Strategic <span class="text-violet-500">Leadership</span>
          </h1>
          <div class="bg-slate-800/50 p-6 rounded-lg border border-violet-500/30 mb-8">
            <p class="text-sm text-violet-500 uppercase tracking-wider mb-2 font-medium">Core Principle</p>
            <p class="text-slate-300 leading-relaxed text-lg">Leading engineering change by focusing equally on technical architecture, data-driven decision-making, and managing the human and organizational components of transformation.</p>
          </div>
        </div>

        <!-- Strategic Leadership Framework -->
        <div class="bg-slate-800/50 rounded-lg border border-violet-500/20 p-12 text-center">
          <svg class="w-16 h-16 text-violet-500/50 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
          <h2 class="text-2xl font-bold text-slate-200 mb-3">Strategic Leadership Framework</h2>
          <p class="text-slate-400 text-lg">Coming Soon</p>
        </div>

        <!-- Back link -->
        <div class="mt-16 text-center">
          <a href="/leadership/devex-qe-leader" class="inline-flex items-center gap-2 text-emerald-500 hover:text-emerald-400 transition-colors font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to DevEx & QE Leadership
          </a>
        </div>
      </div>
    </section>
    <Contact />
  </div>
</Layout>
